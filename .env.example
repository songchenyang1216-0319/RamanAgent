# ========== LLM / API 配置 ==========
SILICONFLOW_API_KEY=your_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# 兼容部分模块使用的通用 LLM 配置
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=1200

# ========== 应用基础配置 ==========
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ========== 业务默认值 ==========
METHANOL_UNIT=%
MODEL_DISAGREEMENT_ABS_THRESHOLD=1.0
MODEL_DISAGREEMENT_REL_THRESHOLD=0.05
MODEL_DISAGREEMENT_LOW_VALUE_THRESHOLD=5
MODEL_DISAGREEMENT_LOW_ABS_THRESHOLD=0.2
