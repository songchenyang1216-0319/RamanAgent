# ============================================================
# 当前默认大模型
# ============================================================
LLM_PROVIDER=sensenova
LLM_MODEL=sensenova-6.7-flash-lite
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_STREAM=true

# 兼容旧代码保留字段
LLM_BASE_URL=https://token.sensenova.cn/v1

# ============================================================
# 商汤日日新 / SenseNova
# ============================================================
SENSENOVA_API_KEY=your_sensenova_api_key
SENSENOVA_BASE_URL=https://token.sensenova.cn/v1
SENSENOVA_DEFAULT_MODEL=sensenova-6.7-flash-lite
SENSENOVA_AVAILABLE_MODELS=sensenova-6.7-flash-lite,deepseek-v4-flash

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-5.4-mini
OPENAI_AVAILABLE_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.4-nano,gpt-4.1,gpt-4.1-mini

# ============================================================
# 通义千问 / Qwen
# ============================================================
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_DEFAULT_MODEL=qwen-plus
QWEN_AVAILABLE_MODELS=qwen-plus,qwen-flash,qwen-turbo,qwen3-coder-plus

# ============================================================
# 智谱 / Zhipu / GLM
# ============================================================
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_DEFAULT_MODEL=glm-5-turbo
ZHIPU_AVAILABLE_MODELS=glm-5,glm-5-turbo,glm-4.7,glm-4.6,glm-4.5,glm-4-plus,glm-4-air,glm-4-flash

# ============================================================
# 硅基流动 / SiliconFlow
# ============================================================
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_DEFAULT_MODEL=Qwen/Qwen3-32B
SILICONFLOW_AVAILABLE_MODELS=Qwen/Qwen3-32B,Qwen/Qwen3-14B,Qwen/Qwen2.5-72B-Instruct,deepseek-ai/DeepSeek-V3,deepseek-ai/DeepSeek-R1,THUDM/GLM-4-9B-0414

# ============================================================
# Gemini
# ============================================================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_AVAILABLE_MODELS=gemini-2.5-flash,gemini-2.5-pro,gemini-2.0-flash

# ============================================================
# Ollama
# ============================================================
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_AVAILABLE_MODELS=qwen2.5:7b,qwen2.5:14b,qwen2.5-coder:7b,llama3.1:8b,deepseek-r1:7b

# ============================================================
# 模型列表刷新
# ============================================================
MODEL_REFRESH_ENABLED=true
MODEL_REFRESH_TIMEOUT_SECONDS=20
MODEL_REFRESH_CACHE_SECONDS=3600

# ============================================================
# 应用基础配置
# ============================================================
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ============================================================
# Workspace / 上下文记忆 / 任务记录
# ============================================================
WORKSPACE_ROOT=./workspace
STORAGE_ROOT=./storage
DEFAULT_USER_ID=default_user
DEFAULT_CONVERSATION_ID=default_conversation
CONTEXT_SUMMARY_MAX_CHARS=8000
RECENT_MESSAGES_LIMIT=10
USER_MEMORY_ENABLED=true

# ============================================================
# 联网搜索 / Web Search
# ============================================================
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=20
WEB_SEARCH_REQUIRE_CITATIONS=true
WEB_SEARCH_FALLBACK_PROVIDER=duckduckgo

TAVILY_API_KEY=your_tavily_api_key
TAVILY_SEARCH_DEPTH=basic
TAVILY_INCLUDE_ANSWER=false
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_INCLUDE_IMAGES=false

# ============================================================
# 业务默认值
# ============================================================
METHANOL_UNIT=%
MODEL_DISAGREEMENT_ABS_THRESHOLD=1.0
MODEL_DISAGREEMENT_REL_THRESHOLD=0.05
MODEL_DISAGREEMENT_LOW_VALUE_THRESHOLD=5
MODEL_DISAGREEMENT_LOW_ABS_THRESHOLD=0.2
